<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="OficinaMecanica.Views.Clientes.ClienteFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Cliente">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Nome -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Nome completo *" FontAttributes="Bold" FontSize="13"/>
                <Border StrokeShape="RoundRectangle 8" Stroke="#ccc">
                    <Entry x:Name="EntryNome" Placeholder="Nome do cliente" Margin="12,0"/>
                </Border>
            </VerticalStackLayout>

            <!-- CPF/CNPJ -->
            <VerticalStackLayout Spacing="4">
                <Label Text="CPF / CNPJ *" FontAttributes="Bold" FontSize="13"/>
                <Border StrokeShape="RoundRectangle 8" Stroke="#ccc">
                    <Entry x:Name="EntryCpfCnpj"
                           Placeholder="000.000.000-00 ou 00.000.000/0001-00"
                           Keyboard="Numeric"
                           Margin="12,0"/>
                </Border>
            </VerticalStackLayout>

            <!-- Telefone -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Telefone" FontAttributes="Bold" FontSize="13"/>
                <Border StrokeShape="RoundRectangle 8" Stroke="#ccc">
                    <Entry x:Name="EntryTelefone"
                           Placeholder="(00) 00000-0000"
                           Keyboard="Telephone"
                           Margin="12,0"/>
                </Border>
            </VerticalStackLayout>

            <!-- E-mail -->
            <VerticalStackLayout Spacing="4">
                <Label Text="E-mail" FontAttributes="Bold" FontSize="13"/>
                <Border StrokeShape="RoundRectangle 8" Stroke="#ccc">
                    <Entry x:Name="EntryEmail"
                           Placeholder="email@exemplo.com"
                           Keyboard="Email"
                           Margin="12,0"/>
                </Border>
            </VerticalStackLayout>

            <!-- Endereço -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Endereço" FontAttributes="Bold" FontSize="13"/>
                <Border StrokeShape="RoundRectangle 8" Stroke="#ccc">
                    <Entry x:Name="EntryEndereco" Placeholder="Rua, número, bairro" Margin="12,0"/>
                </Border>
            </VerticalStackLayout>

            <!-- Cidade e Estado em linha -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="Cidade" FontAttributes="Bold" FontSize="13"/>
                    <Border StrokeShape="RoundRectangle 8" Stroke="#ccc">
                        <Entry x:Name="EntryCidade" Placeholder="Cidade" Margin="12,0"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="4" WidthRequest="70">
                    <Label Text="UF" FontAttributes="Bold" FontSize="13"/>
                    <Border StrokeShape="RoundRectangle 8" Stroke="#ccc">
                        <Entry x:Name="EntryEstado"
                               Placeholder="SP"
                               MaxLength="2"
                               Margin="12,0"/>
                    </Border>
                </VerticalStackLayout>
            </Grid>

            <!-- Mensagem de erro -->
            <Label x:Name="LabelErro"
                   TextColor="#e74c3c"
                   FontSize="13"
                   IsVisible="False"/>

            <!-- Botão salvar -->
            <Button
                x:Name="BtnSalvar"
                Text="Salvar"
                Clicked="OnSalvarClicked"
                BackgroundColor="#2e86c1"
                TextColor="White"
                FontAttributes="Bold"
                HeightRequest="50"
                CornerRadius="10"
                Margin="0,8,0,0"/>

            <ActivityIndicator
                x:Name="Carregando"
                IsRunning="False"
                IsVisible="False"
                Color="#2e86c1"
                HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
